@model SendInvitationViewModel

<div class="container w-50 mx-auto">

    <h2>Invite Participants</h2>

    <form asp-action="Invite" method="post">

        <input asp-for="SurveyId" type="hidden" />

        <div class="mb-3">
            <label class="form-label">
                Email Addresses (one per line)
            </label>

            <textarea asp-for="Emails"
                      class="form-control"
                      rows="8"
                      placeholder="john@example.com&#10;jane@example.com"></textarea>
        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-primary w-50">
                Send Invitations
            </button>

            <a asp-controller="Survey"
               asp-action="Details"
               asp-route-id="@Model.SurveyId"
               class="btn btn-outline-secondary w-50">
                Cancel
            </a>

        </div>

    </form>

</div>